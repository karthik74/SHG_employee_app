# Copy this file to .env and fill in real values. Never commit .env.
#
# IMPORTANT: This .env file is consumed ONLY by debug/profile builds as a
# developer convenience. It is NOT bundled as an asset and is NOT read by
# release builds. For production/release builds, pass configuration via
# compile-time --dart-define flags, for example:
#
#   flutter build apk --release \
#     --dart-define=API_BASE_URL=https://navachetana.co.in/backend/fineract-provider/api/v1 \
#     --dart-define=TENANT_ID=default \
#     --dart-define=DEV_MODE=false
#
API_BASE_URL=https://navachetana.co.in/backend/fineract-provider/api/v1
TENANT_ID=default
# DEV_MODE=true allows self-signed certificates in DEBUG BUILDS ONLY.
# Release builds always enforce TLS verification regardless of this flag.
DEV_MODE=false
